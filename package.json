{
  "name": "recruitment-need-analysis-ai",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build && node scripts/copy-hosting-metadata.mjs",
    "start": "vinext start",
    "dev:next": "next dev",
    "build:next": "next build",
    "start:next": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "vinext typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "widget:build": "node scripts/build-widget.mjs",
    "mcp": "tsx mcp/stdio.ts",
    "sites:archive": "bash scripts/package-sites-archive.sh",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "1.7.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "next": "16.2.10",
    "openai": "6.47.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-server-dom-webpack": "19.2.7",
    "vinext": "1.0.0-beta.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.16.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-rsc": "0.5.27",
    "esbuild": "0.28.1",
    "eslint": "9.30.1",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.19",
    "tsx": "4.20.3",
    "typescript": "5.9.3",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "overrides": {
    "postcss": "8.5.19"
  },
  "type": "module"
}
