# Server-only. Never prefix secrets with NEXT_PUBLIC_.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
ESCO_API_BASE_URL=https://ec.europa.eu/esco/api
# Dedicated HMAC secret for server-verifiable ESCO provenance. Generate at
# least 32 random bytes; never derive this from OPENAI_API_KEY.
ESCO_PROVENANCE_SIGNING_SECRET=

# Server-only retrieval resources. Use IDs from the same OpenAI project as
# OPENAI_API_KEY. Keep real IDs in .env.local or the deployment secret store.
OPENAI_ESCO_VECTOR_STORE_ID=
OPENAI_JOB_POSTINGS_VECTOR_STORE_ID=
OPENAI_MARKET_VECTOR_STORE_ID=

# Completed, indexed aggregate salary reference used at runtime. Keep the
# larger failed 2025 upload below as a separate maintenance/repair reference.
OPENAI_SALARY_REFERENCE_FILE_ID=
# Deliberate local/demo opt-in only. Leave false until source rights are verified.
OPENAI_ALLOW_UNVERIFIED_SALARY_REFERENCE=false
# Owner-only demo escape hatch for existing licensed job-posting attachments
# that predate explicit rights_status/privacy_status metadata. Never public.
OPENAI_ALLOW_LEGACY_JOB_POSTING_GOVERNANCE=false

# In-process guard for the recruitment-knowledge route. Values are bounded at
# runtime (rate: 1..120/min, TTL: 1s..15min, cache: max 100 entries).
KNOWLEDGE_RATE_LIMIT_PER_MINUTE=20
KNOWLEDGE_CACHE_TTL_MS=300000
KNOWLEDGE_CACHE_MAX_ENTRIES=100
# Enable only when the deployment edge overwrites client-supplied proxy headers.
KNOWLEDGE_TRUST_PROXY_HEADERS=false

# Source-maintenance IDs used by the read-only readiness diagnostic. Raw files
# marked as blocked in README.md must not be attached until their stated review
# or sharding gate has passed.
OPENAI_SALARY_FILE_ID=
OPENAI_RESUME_ENTITIES_FILE_ID=
OPENAI_IT_JOB_DESCRIPTIONS_FILE_ID=
OPENAI_HIRING_TRENDS_FILE_ID=
OPENAI_JOB_REPORT_FILE_ID=

# Optional real market-data adapter. Without it, the app uses an explicitly
# labelled synthetic scenario model and never claims observed salary or supply.
MARKET_DATA_API_URL=
MARKET_DATA_API_KEY=
